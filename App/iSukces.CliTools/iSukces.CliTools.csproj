<?xml version="1.0" encoding="utf-8"?>
<Project Sdk="Microsoft.NET.Sdk">
  <PropertyGroup>
    <Title>iSukces.CliTools - .NET helpers for running external CLI processes</Title>
    <Description>.NET helper library for running external command-line tools. It supports asynchronous process execution, argument collection, environment variable updates, stdout/stderr capture, tail-style console output, exit-code handling, and Result-based wrappers.</Description>
    <Copyright>Copyright © Internet Sukces Piotr Stęclik 2026</Copyright>
    <Authors>Internet Sukces Piotr Stęclik</Authors>
    <Company>Internet Sukces Piotr Stęclik</Company>
    <ProjectGuid>6C4D0274-DE79-438C-9424-F23CA815415D</ProjectGuid>
    <TargetFramework>net10.0</TargetFramework>
    <AssemblyVersion>1.26.713.1</AssemblyVersion>
    <FileVersion>1.26.713.1</FileVersion>
    <Version>1.26.713.1</Version>
    <LangVersion>14</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <Nullable>enable</Nullable>
    <GeneratePackageOnBuild>true</GeneratePackageOnBuild>
    <ContinuousIntegrationBuild>true</ContinuousIntegrationBuild>
    <PackageLicenseExpression>MIT</PackageLicenseExpression>
    <SymbolPackageFormat>snupkg</SymbolPackageFormat>
    <EmbedUntrackedSources>true</EmbedUntrackedSources>
    <IncludeSource>false</IncludeSource>
    <IncludeSymbols>true</IncludeSymbols>
    <PackageProjectUrl>https://github.com/isukces/iSukces.Cli</PackageProjectUrl>
    <RepositoryUrl>https://github.com/isukces/iSukces.Cli</RepositoryUrl>
    <PackageReadmeFile>readme.md</PackageReadmeFile>
    <PackageTags>cli;command-line;process;arguments;environment;stdout;stderr;dotnet;csharp</PackageTags>
  </PropertyGroup>
  <ItemGroup>
    <PackageReference Include="iSukces.Translation" Version="1.26.204.17" />
    <PackageReference Include="Microsoft.SourceLink.GitHub" Version="10.0.300">
      <PrivateAssets>all</PrivateAssets>
      <IncludeAssets>runtime; build; native; contentfiles; analyzers; buildtransitive</IncludeAssets>
    </PackageReference>
    <PackageReference Include="Newtonsoft.Json" Version="13.0.4" />
    <PackageReference Include="YamlDotNet" Version="18.1.0" />
  </ItemGroup>
  <ItemGroup>
    <None Remove="Processors\Resources\*.txt" />
    <EmbeddedResource Include="Processors\Resources\*.txt" />
    <None Include="readme.md" Pack="true" PackagePath="\" />
  </ItemGroup>
</Project>